{
  "name": "table",
  "version": "1.1.0",
  "private": true,
  "description": "个人工作台应用 — React + FastAPI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bin3413532696-dev/Table.git"
  },
  "scripts": {
    "dev": "webpack serve",
    "backend:sync": "uv sync --package table-python-backend",
    "ocr:dev": "uv run --package table-ocr-service uvicorn main:app --host 127.0.0.1 --port 8001 --reload",
    "backend:dev": "uv run --package table-python-backend uvicorn app.main:app --host 127.0.0.1 --port 8787 --reload",
    "backend:test": "uv run --package table-python-backend pytest python-backend/tests -q",
    "knowledge:smoke": "node scripts/smoke/knowledge-notes-smoke.mjs",
    "knowledge-rag:smoke": "node scripts/smoke/knowledge-rag-smoke.mjs",
    "agent-rag:smoke": "node scripts/smoke/agent-rag-smoke.mjs",
    "agent-memory:smoke": "node scripts/smoke/agent-memory-smoke.mjs",
    "modules:smoke": "node scripts/smoke/tasks-finance-smoke.mjs",
    "build": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "test:frontend-api": "tsc -p tsconfig.frontend-tests.json && node --test \"dist-frontend-tests/tests/frontend-api/*.test.js\"",
    "agent:e2e": "node scripts/e2e/agent-e2e-cdp.mjs",
    "knowledge:e2e": "node scripts/e2e/knowledge-notes-e2e-cdp.mjs",
    "agent:modules:e2e": "node scripts/e2e/agent-modules-e2e-cdp.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@prisma/client": "^6.19.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/markdown": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/suggestion": "^3.22.4",
    "@uiw/react-codemirror": "^4.25.9",
    "d3": "^7.9.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.16.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.8.0",
    "recharts": "^2.10.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.5",
    "@babel/preset-typescript": "^7.23.5",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.15.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "chokidar": "^5.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "prisma": "^6.7.0",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
