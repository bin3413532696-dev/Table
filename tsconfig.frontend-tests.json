{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "outDir": "dist-frontend-tests",
    "rootDir": ".",
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/core/**/*.ts",
    "src/features/**/*.ts",
    "src/features/**/*.tsx",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx",
    "tests/frontend-api/**/*.ts",
    "tests/frontend-api/**/*.tsx"
  ]
}
