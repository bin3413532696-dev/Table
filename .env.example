DEFAULT_PROVIDER_NAME=GLM-5 Provider
DEFAULT_PROVIDER_FORMAT=openai
DEFAULT_PROVIDER_BASE_URL=
DEFAULT_PROVIDER_API_KEY=
DEFAULT_PROVIDER_MODEL=

# RAG embedding 覆盖配置（可选，不设置则使用活跃 Provider）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# 查询预处理（可选）
QUERY_PREPROCESSOR_ENABLED=false
QUERY_EXPANSION_COUNT=3
QUERY_REWRITE_ENABLED=true
QUERY_PREPROCESSOR_TIMEOUT_MS=10000

# MMR 重排（可选）
MMR_ENABLED=false
MMR_LAMBDA=0.7

# Cross-Encoder 重排（可选）
RERANKER_ENABLED=false
RERANKER_TOP_N=20
RERANKER_TIMEOUT_MS=2000
RERANKER_MIN_SCORE=0.3
RERANKER_MAX_TOKENS=400

# PDF 质量预检（可选，默认开启）
RAG_QUALITY_PREFLIGHT_ENABLED=true
RAG_QUALITY_PREFLIGHT_MAX_PAGES=3
RAG_QUALITY_MIN_VALID_RATIO=0.80
RAG_QUALITY_SCAN_DETECTION_CHARS=50

# PDF 快速路径（有文本层时跳过 OCR）
RAG_PDF_TEXT_FAST_PATH_MIN_CHARS=500

# PDF 解析（MarkItDown 主路径 + PyMuPDF 提图）
RAG_PDF_PARSER=markitdown
RAG_PDF_MARKITDOWN_MIN_CHARS=200
RAG_PDF_EXTRACT_IMAGES_ENABLED=true
RAG_PDF_VECTOR_GRAPHICS_MIN_SIZE=100
RAG_PDF_VECTOR_GRAPHICS_MIN_PATHS=5

# VLM 图片描述（图转文，需配置 API key 或活跃 Provider）
RAG_VISION_LLM_ENABLED=true
RAG_VISION_LLM_MODEL=gpt-4o
RAG_VISION_LLM_API_KEY=
RAG_VISION_LLM_BASE_URL=
RAG_VISION_LLM_TIMEOUT_MS=30000
RAG_VISION_LLM_MAX_RETRIES=2
RAG_VISION_LLM_MAX_IMAGES_PER_DOC=50
RAG_VISION_LLM_MAX_CONCURRENCY=3

SERVER_HOST=127.0.0.1
SERVER_PORT=8787
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/table_dev
ALLOW_DEFAULT_USER_FALLBACK=true
TRUST_USER_ID_HEADER=false

DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
PROVIDER_SECRET_KEY=change-this-provider-secret-key

PROJECTION_OUTBOX_POLL_MS=1500
PROJECTION_OUTBOX_BATCH_SIZE=20
