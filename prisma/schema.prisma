generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String?            @unique
  displayName      String             @map("display_name")
  status           String             @default("active")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  agentSessions    AgentSession[]
  runs             AgentRun[]
  providers        ApiProvider[]
  finances         FinanceRecord[]
  knowledgeNotes   KnowledgeNote[]
  knowledgePresetTags KnowledgePresetTag[]
  knowledgeDocuments KnowledgeDocument[]
  knowledgeCorpora  KnowledgeCorpus[]
  knowledgeCorpusDocuments KnowledgeCorpusDocument[]
  knowledgeChunks KnowledgeChunk[]
  knowledgeEmbeddingCache KnowledgeEmbeddingCache[]
  knowledgeIndexJobs KnowledgeIndexJob[]
  agentMemoryEvents AgentMemoryEvent[]
  agentMemoryRecords AgentMemoryRecord[]
  agentMemoryBlocks AgentMemoryBlock[]
  tasks            Task[]
  settings         UserSetting?

  @@map("users")
}

model AgentSession {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String     @map("user_id") @db.Uuid
  title                 String     @default("新会话")
  memorySummary         String     @default("") @map("memory_summary")
  memoryPreferencesJson Json       @default("[]") @map("memory_preferences_json")
  memoryFactsJson       Json       @default("[]") @map("memory_facts_json")
  memoryGoalsJson       Json       @default("[]") @map("memory_goals_json")
  memoryTodosJson       Json       @default("[]") @map("memory_todos_json")
  memoryRulesJson       Json       @default("[]") @map("memory_rules_json")
  memoryStatus          String     @default("idle") @map("memory_status")
  memoryUpdatedAt       DateTime?  @map("memory_updated_at") @db.Timestamptz(6)
  memoryDisabled        Boolean    @default(false) @map("memory_disabled")
  memoryRunCount        Int        @default(0) @map("memory_run_count")
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  runs                  AgentRun[]
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("agent_sessions")
}

model AgentRun {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String       @map("user_id") @db.Uuid
  sessionId              String       @map("session_id") @db.Uuid
  status                 String
  inputText              String       @map("input_text")
  model                  String
  messagesJson           Json         @default("[]") @map("messages_json")
  executedToolCallsJson  Json         @default("[]") @map("executed_tool_calls_json")
  pendingToolCallsJson   Json         @default("[]") @map("pending_tool_calls_json")
  assistantTextChunksJson Json        @default("[]") @map("assistant_text_chunks_json")
  timelineJson           Json         @default("[]") @map("timeline_json")
  finalText              String       @default("") @map("final_text")
  errorText              String?      @map("error_text")
  iterationCount         Int          @default(0) @map("iteration_count")
  requiresConfirmation   Boolean      @default(false) @map("requires_confirmation")
  createdAt              DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version                Int          @default(1)
  user                   User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  session                AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("agent_runs")
}

model UserSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String   @default("light")
  profile_json         Json     @default("{}")
  notification_json    Json     @default("{}")
  securityPinHash      String?  @map("security_pin_hash")
  agentPreferencesJson Json     @default("{}") @map("agent_preferences_json")
  providerConfigHash   String?  @map("provider_config_hash")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version              Int      @default(1)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_settings")
}

model ApiProvider {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  apiFormat       String   @map("api_format")
  baseUrl         String   @map("base_url")
  apiKeyEncrypted String?  @map("api_key_encrypted")
  model           String?
  embeddingModel  String?  @map("embedding_model")
  rerankerModel   String?  @map("reranker_model")
  headersJson     Json     @default("{}") @map("headers_json")
  isActive        Boolean  @default(false) @map("is_active")
  source          String   @default("manual") @map("source")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version         Int      @default(1)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("api_providers")
}

model Task {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String
  completed Boolean   @default(false)
  priority  String    @default("medium")
  dueDate   DateTime? @map("due_date") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version   Int       @default(1)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("tasks")
}

model FinanceRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String
  amount       Decimal  @db.Decimal(18, 2)
  category     String
  description  String
  recordDate   DateTime @map("record_date") @db.Date
  model        String?
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version      Int      @default(1)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("finance_records")
}

model KnowledgeNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  content   String   @default("")
  tagsJson  Json     @default("[]") @map("tags_json")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("knowledge_notes")
}

model KnowledgePresetTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String   @default("#6B7280")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, name])
  @@index([userId, sortOrder])
  @@map("knowledge_preset_tags")
}

model KnowledgeCorpus {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                    @map("user_id") @db.Uuid
  name            String
  description     String                    @default("")
  defaultTagsJson Json                      @default("[]") @map("default_tags_json")
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  documents       KnowledgeCorpusDocument[]

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("knowledge_corpora")
}

model KnowledgeCorpusDocument {
  corpusId   String          @map("corpus_id") @db.Uuid
  documentId String          @map("document_id") @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  sortOrder  Int             @default(0) @map("sort_order")
  addedAt    DateTime        @default(now()) @map("added_at") @db.Timestamptz(6)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  corpus     KnowledgeCorpus @relation(fields: [corpusId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([corpusId, documentId])
  @@index([userId])
  @@index([documentId])
  @@map("knowledge_corpus_documents")
}

// =====================================================
// RAG 知识库模型
// =====================================================

model KnowledgeDocument {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  title        String
  summary      String?             @default("")
  content      String?             @default("")
  source       String?
  fileType     String?             @map("file_type")
  fileSize     Int?                @default(0) @map("file_size")
  status       String?             @default("pending")
  tagsJson     Json?               @default("[]") @map("tags_json")
  contentHash  String?             @map("content_hash")
  version      Int?                @default(1)

  // === 结构化元数据 ===
  publishDate      DateTime?       @map("publish_date") @db.Date
  sourceDept       String?         @map("source_dept")
  securityLevel    String?         @map("security_level")
  businessCategory String?         @map("business_category")
  docLanguage      String?         @default("zh") @map("doc_language")

  // === 解析质量 ===
  parseQuality     String?         @map("parse_quality")
  hasOcr           Boolean         @default(false) @map("has_ocr")
  originalMetadata Json?           @map("original_metadata")

  createdAt    DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?           @default(now()) @map("updated_at") @db.Timestamptz(6)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chunks       KnowledgeChunk[]
  indexJobs    KnowledgeIndexJob[]
  corpora      KnowledgeCorpusDocument[]

  @@index([userId, status], map: "knowledge_documents_status_idx")
  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)], map: "knowledge_documents_user_updated_idx")
  @@index([userId, publishDate(sort: Desc)], map: "knowledge_documents_publish_date_idx")
  @@index([userId, sourceDept], map: "knowledge_documents_source_dept_idx")
  @@index([userId, securityLevel], map: "knowledge_documents_security_level_idx")
  @@index([userId, businessCategory], map: "knowledge_documents_business_category_idx")
  @@index([userId, publishDate(sort: Desc), sourceDept], map: "knowledge_documents_date_dept_idx")
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId         String    @map("document_id") @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  content            String
  contentHash        String    @map("content_hash")
  chunkIndex         Int?      @default(0) @map("chunk_index")
  startPos           Int?      @default(0) @map("start_pos")
  endPos             Int?      @default(0) @map("end_pos")
  embedding          Unsupported("vector(1024)")?
  embeddingModel     String?   @map("embedding_model")
  createdAt          DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime? @default(now()) @db.Timestamptz(6)
  headingChain       String?   @map("heading_chain")
  headingLevel       Int?      @map("heading_level")
  embeddingDimensions Int?     @map("embedding_dimensions")
  embeddingVersion   Int?      @default(1) @map("embedding_version")

  // === 小块大块架构 (Parent-Child) ===
  parentId           String?   @map("parent_id") @db.Uuid        // 大块ID，小块关联大块
  chunkType          String    @default("small") @map("chunk_type") // "small" | "parent"

  document           KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // === 自引用关系：小块 -> 大块 ===
  parent             KnowledgeChunk?  @relation("ChunkHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children           KnowledgeChunk[] @relation("ChunkHierarchy")

  @@index([documentId])
  @@index([documentId, chunkIndex], map: "knowledge_chunks_document_index_idx")
  @@index([userId])
  @@index([embeddingVersion], map: "knowledge_chunks_embedding_version_idx")
  @@index([parentId], map: "knowledge_chunks_parent_id_idx")
  @@index([documentId, chunkType], map: "knowledge_chunks_document_type_idx")
  @@map("knowledge_chunks")
}

model KnowledgeEmbeddingCache {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String              @map("user_id") @db.Uuid
  contentHash   String              @map("content_hash")
  embedding     Unsupported("vector(1024)")
  embeddingModel String             @map("embedding_model")
  createdAt     DateTime?           @default(now()) @db.Timestamptz(6)
  expiresAt     DateTime?           @map("expires_at") @db.Timestamptz(6)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentHash, embeddingModel], map: "knowledge_embedding_cache_unique_idx")
  @@index([contentHash], map: "knowledge_embedding_cache_hash_idx")
  @@index([expiresAt], map: "knowledge_embedding_cache_expires_idx")
  @@map("knowledge_embedding_cache")
}

model KnowledgeIndexJob {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  documentId  String?            @map("document_id") @db.Uuid
  jobType     String             @map("job_type")
  status      String             @default("pending")
  progress    Int?               @default(0)
  errorJson   Json?              @map("error_json")
  startedAt   DateTime?          @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?          @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId, status], map: "knowledge_index_jobs_user_status_idx")
  @@index([documentId], map: "knowledge_index_jobs_document_idx")
  @@map("knowledge_index_jobs")
}

// =====================================================
// LangGraph Checkpointer 模型
// =====================================================

model Checkpoint {
  threadId     String   @map("thread_id")
  checkpointNs String   @default("") @map("checkpoint_ns")
  checkpointId String   @map("checkpoint_id")
  parentCheckpointId String? @map("parent_checkpoint_id")
  type         String
  checkpoint   Json
  metadata     Json
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([threadId, checkpointNs, checkpointId])
  @@index([threadId])
  @@index([threadId, checkpointNs])
  @@map("checkpoints")
}

model CheckpointBlob {
  threadId     String
  checkpointNs String @default("") @map("checkpoint_ns")
  channel      String
  version      String
  type         String
  blob         Bytes?

  @@id([threadId, checkpointNs, channel, version])
  @@map("checkpoint_blobs")
}

model CheckpointWrite {
  threadId     String
  checkpointNs String @default("") @map("checkpoint_ns")
  checkpointId String @map("checkpoint_id")
  channel      String
  type         String
  blob         Bytes
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([threadId, checkpointNs, checkpointId, channel])
  @@index([threadId])
  @@index([threadId, checkpointNs, checkpointId])
  @@map("checkpoint_writes")
}

model CheckpointMigration {
  v Int @id
  @@map("checkpoint_migrations")
}

model AgentMemoryEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  runId       String   @map("run_id") @db.Uuid
  eventType   String   @map("event_type")
  payloadJson Json     @default("{}") @map("payload_json")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([runId])
  @@index([userId, status])
  @@map("agent_memory_events")
}

model AgentMemoryRecord {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  scopeType        String   @map("scope_type")
  scopeId          String   @map("scope_id")
  memoryKind       String   @map("memory_kind")
  memorySlot       String   @map("memory_slot")
  title            String   @default("")
  content          String   @default("")
  summary          String   @default("")
  confidence       Decimal  @default(0.5) @db.Decimal(4, 3)
  salience         Decimal  @default(0.5) @db.Decimal(4, 3)
  sourceRunId      String?  @map("source_run_id") @db.Uuid
  sourceDocumentId String?  @map("source_document_id") @db.Uuid
  evidenceJson     Json     @default("{}") @map("evidence_json")
  lastAccessedAt   DateTime? @map("last_accessed_at") @db.Timestamptz(6)
  accessCount      Int      @default(0) @map("access_count")
  supersedesId     String?  @map("supersedes_id") @db.Uuid
  ttlAt            DateTime? @map("ttl_at") @db.Timestamptz(6)
  isDeleted        Boolean  @default(false) @map("is_deleted")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, scopeType, scopeId])
  @@index([userId, memoryKind, memorySlot])
  @@index([userId, isDeleted])
  @@map("agent_memory_records")
}

model AgentMemoryBlock {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  blockType String   @map("block_type")
  scopeType String   @map("scope_type")
  scopeId   String   @map("scope_id")
  content   String   @default("")
  version   Int      @default(1)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@unique([userId, blockType, scopeType, scopeId])
  @@map("agent_memory_blocks")
}
