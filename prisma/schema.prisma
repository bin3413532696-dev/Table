generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String?            @unique
  displayName      String             @map("display_name")
  status           String             @default("active")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  agentSessions    AgentSession[]
  providers        ApiProvider[]
  finances         FinanceRecord[]
  knowledgeNotes   KnowledgeNote[]
  knowledgePresetTags KnowledgePresetTag[]
  tasks            Task[]
  settings         UserSetting?

  @@map("users")
}

model AgentSession {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  title     String     @default("新会话")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  runs      AgentRun[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("agent_sessions")
}

model AgentRun {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  sessionId    String       @map("session_id") @db.Uuid
  status       String
  inputText    String       @map("input_text")
  model        String
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version      Int          @default(1)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  session      AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("agent_runs")
}

model UserSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String   @default("light")
  profile_json         Json     @default("{}")
  notification_json    Json     @default("{}")
  securityPinHash      String?  @map("security_pin_hash")
  agentPreferencesJson Json     @default("{}") @map("agent_preferences_json")
  providerConfigHash   String?  @map("provider_config_hash")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version              Int      @default(1)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_settings")
}

model ApiProvider {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  apiFormat       String   @map("api_format")
  baseUrl         String   @map("base_url")
  apiKeyEncrypted String?  @map("api_key_encrypted")
  model           String?
  headersJson     Json     @default("{}") @map("headers_json")
  isActive        Boolean  @default(false) @map("is_active")
  source          String   @default("manual") @map("source")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version         Int      @default(1)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("api_providers")
}

model Task {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String
  completed Boolean   @default(false)
  priority  String    @default("medium")
  dueDate   DateTime? @map("due_date") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version   Int       @default(1)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("tasks")
}

model FinanceRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String
  amount       Decimal  @db.Decimal(18, 2)
  category     String
  description  String
  recordDate   DateTime @map("record_date") @db.Date
  model        String?
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version      Int      @default(1)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("finance_records")
}

model KnowledgeNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  content   String   @default("")
  tagsJson  Json     @default("[]") @map("tags_json")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("knowledge_notes")
}

model KnowledgePresetTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String   @default("#6B7280")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, name])
  @@index([userId, sortOrder])
  @@map("knowledge_preset_tags")
}