generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String?            @unique
  displayName      String             @map("display_name")
  status           String             @default("active")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  agentRuns        AgentRun[]
  agentMessages    AgentMessage[]
  agentRunSnapshots AgentRunStateSnapshot[]
  providers        ApiProvider[]
  finances         FinanceRecord[]
  knowledgeNotes   KnowledgeNote[]
  knowledgePresetTags KnowledgePresetTag[]
  tasks            Task[]
  settings         UserSetting?
  toolExecutions   ToolExecution[]

  @@map("users")
}

model AgentRun {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String                  @map("user_id") @db.Uuid
  sessionId            String?                 @map("session_id") @db.Uuid
  status               String
  inputText            String                  @map("input_text")
  model                String
  requiresConfirmation Boolean                 @default(false) @map("requires_confirmation")
  errorMessage         String?                 @map("error_message")
  startedAt            DateTime                @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt           DateTime?               @map("finished_at") @db.Timestamptz(6)
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version              Int                     @default(1)
  user                 User                    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages             AgentMessage[]
  toolExecutions       ToolExecution[]
  stateSnapshots       AgentRunStateSnapshot[]

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("agent_runs")
}

model AgentMessage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  runId        String   @map("run_id") @db.Uuid
  role         String
  content      String
  sequence     Int
  metadataJson Json     @default("{}") @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  run          AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([runId, sequence])
  @@index([runId, sequence])
  @@index([userId, createdAt(sort: Desc)])
  @@map("agent_messages")
}

model ToolExecution {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String    @map("user_id") @db.Uuid
  runId                   String    @map("run_id") @db.Uuid
  toolName                String    @map("tool_name")
  argumentsJson           Json      @default("{}") @map("arguments_json")
  status                  String
  requiresConfirmation    Boolean   @default(false) @map("requires_confirmation")
  confirmationRequestedAt DateTime? @map("confirmation_requested_at") @db.Timestamptz(6)
  confirmedAt             DateTime? @map("confirmed_at") @db.Timestamptz(6)
  resultJson              Json?     @map("result_json")
  errorMessage            String?   @map("error_message")
  sequence                Int
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                    User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  run                     AgentRun  @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([runId, sequence])
  @@index([runId, sequence])
  @@index([status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("tool_executions")
}

model AgentRunStateSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  runId        String   @map("run_id") @db.Uuid
  snapshotJson Json     @map("snapshot_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  run          AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([runId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("agent_run_state_snapshots")
}

model UserSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  theme                String   @default("light")
  profile_json         Json     @default("{}")
  notification_json    Json     @default("{}")
  securityPinHash      String?  @map("security_pin_hash")
  agentPreferencesJson Json     @default("{}") @map("agent_preferences_json")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  version              Int      @default(1)
  user                 User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_settings")
}

model ApiProvider {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  name            String
  apiFormat       String    @map("api_format")
  baseUrl         String    @map("base_url")
  apiKeyEncrypted String?   @map("api_key_encrypted")
  model           String?
  headersJson     Json      @default("{}") @map("headers_json")
  isActive        Boolean   @default(false) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  version         Int       @default(1)
  user            User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("api_providers")
}

model Task {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String
  completed Boolean   @default(false)
  priority  String    @default("medium")
  dueDate   DateTime? @map("due_date") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  version   Int       @default(1)
  user      User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, deletedAt])
  @@map("tasks")
}

model FinanceRecord {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  type         String
  amount       Decimal   @db.Decimal(18, 2)
  category     String
  description  String
  recordDate   DateTime  @map("record_date") @db.Date
  model        String?
  metadataJson Json      @default("{}") @map("metadata_json")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  version      Int       @default(1)
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, deletedAt])
  @@map("finance_records")
}

model KnowledgeNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  content   String   @default("")
  tagsJson  Json     @default("[]") @map("tags_json")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, deletedAt])
  @@map("knowledge_notes")
}

model KnowledgePresetTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String   @default("#6B7280")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, name])
  @@index([userId, sortOrder])
  @@map("knowledge_preset_tags")
}